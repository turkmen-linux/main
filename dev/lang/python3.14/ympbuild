#!/usr/bin/env bash
name='python3.14'
release='1'
version='3.14.4'
url='https://www.python.org/downloads/'
description='Next generation of the python high-level scripting language'
email='parduscix@yandex.ru'
maintainer='sulincix'
license=('custom')
source=("https://www.python.org/ftp/python/$version/Python-$version.tar.xz"
       'turkman.patch')
depends=('bzip2' 'gdbm'  'libnsl' 'libxcrypt' 'openssl' 'zlib' 'mpdecimal')
makedepends=( )
sha256sums=('d923c51303e38e249136fc1bdf3568d56ecb03214efdef48516176d3d7faaef8'
         'SKIP')
expat_depends=('expat')
arch=('x86_64')
group=(dev.lang python)

export CFLAGS="-O2 -s -flto -ffat-lto-objects"
export CXXFLAGS="-O2 -s -flto -ffat-lto-objects"

export LC_CTYPE=en_US.UTF-8
export LANG=en_US.UTF-8

cd Python-$version

setup(){
    patch -Np1 -i "../turkman.patch"
    ./configure --prefix=/usr \
        --libdir=/usr/lib64 \
        --enable-ipv6 \
		    --enable-loadable-sqlite-extensions \
    		--enable-optimizations \
	    	--enable-shared \
		    --with-computed-gotos \
		    --with-dbmliborder=gdbm:ndbm \
		    --with-system-expat \
        --with-system-libmpdec \
        --without-ensurepip

    sed -i 's/^all:.*$/all: build_all/' Makefile
    env -i PATH=$PATH make $jobs
}

package(){
    env -i PATH=$PATH make install $jobs DESTDIR=$DESTDIR
    # this symlinks provided by main python metapackage
    for bin in pydoc3 idle3 python3 python3-config; do
        rm -f ${DESTDIR}/usr/bin/$bin
    done
    # pip3 command
    echo '#!/bin/sh' > ${DESTDIR}/usr/bin/pip3.14
    echo 'exec python3.14 -m pip "$@"' >> ${DESTDIR}/usr/bin/pip3.14
    rm -f ${DESTDIR}/usr/lib64/pkgconfig/python3.pc
    rm -f ${DESTDIR}/usr/lib64/pkgconfig/python3-embed.pc
    # remove unused file
    rm -f ${DESTDIR}/usr/share/man/man1/python3.1
    # move libpython3.so file
    mv ${DESTDIR}/usr/lib64/libpython3.so ${DESTDIR}/usr/lib64/libpython3.so.3.14
}

